{
  "name": "alexgallery",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22.22.2 <23",
    "pnpm": ">=10.34.1 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm validate-photo-process && next build && pnpm prune-private-assets",
    "optimize-images": "tsx scripts/optimize-images.ts",
    "prepare-photo-process": "tsx scripts/prepare-photo-process.ts",
    "preview": "wrangler dev --port 8788",
    "start": "pnpm preview",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm typecheck",
    "test": "tsx --test tests/**/*.test.ts",
    "validate-photo-process": "tsx scripts/validate-photo-process.ts",
    "prune-private-assets": "tsx scripts/prune-private-assets.ts",
    "export": "next build",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "deploy:wrangler": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "next": "^16.0.0",
    "plaiceholder": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@plaiceholder/next": "^3.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.31.1",
    "@types/three": "^0.185.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "wrangler": "4.112.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@img/sharp-win32-x64",
      "workerd"
    ]
  }
}
