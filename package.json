{
  "name": "alexgallery",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm validate-photo-process && next build",
    "optimize-images": "tsx scripts/optimize-images.ts",
    "prepare-photo-process": "tsx scripts/prepare-photo-process.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm typecheck",
    "test": "tsx --test tests/**/*.test.ts",
    "validate-photo-process": "tsx scripts/validate-photo-process.ts",
    "export": "next build",
    "deploy:wrangler": "pnpm run build && npx wrangler deploy --assets=./out"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "plaiceholder": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-masonry-css": "^1.0.16",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.185.1",
    "yet-another-react-lightbox": "^3.30.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@plaiceholder/next": "^3.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.31.1",
    "@types/three": "^0.185.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@img/sharp-win32-x64"
    ]
  }
