# Required in production. Public build-time canonical URL used by metadata,
# sitemap, robots and structured data. Safe for the browser bundle.
NEXT_PUBLIC_BASE_URL=https://gallery.aleviclop.dev

# Required only when contact and licensing forms must submit. Public build-time
# identifier issued by Web3Forms; restrict it to the production domain there.
# It is exposed in HTML/JavaScript by design and must never be treated as a secret.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=replace-with-your-public-access-key
